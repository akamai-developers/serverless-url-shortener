---
import "../styles/global.css";

interface Props {
  title?: string;
}
const { title = "Serverless URL Shortener" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A Wasm-based serverless URL shortener" />
    <link rel="icon" type="image/svg+xml"
      href="data:image/svg+xml,<svg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 100 100%27><text y=%27.9em%27 font-size=%2790%27>🔗</text></svg>" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
